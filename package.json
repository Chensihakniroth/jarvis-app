{
  "name": "jarvis",
  "productName": "J.A.R.V.I.S.",
  "private": true,
  "version": "0.1.0",
  "description": "J.A.R.V.I.S. — Iron Man-inspired AI desktop assistant with voice conversation",
  "author": "callmemo",
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "start": "concurrently -k \"npm:dev\" \"npm:electron\"",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.23",
    "@assistant-ui/react-streamdown": "^0.3.4",
    "@nanostores/react": "^1.1.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@tabler/icons-react": "^3.44.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/react-query": "^5.101.0",
    "@vscode/codicons": "^0.0.45",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "katex": "^0.17.0",
    "lucide-react": "^1.20.0",
    "motion": "^12.40.0",
    "nanostores": "^1.3.0",
    "radix-ui": "^1.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.170.0",
    "tw-shimmer": "^0.4.11"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "ai.anakot.jarvis",
    "productName": "J.A.R.V.I.S.",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
